<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>BEM Elite Mastery | Dr. Mohamed Chouidira</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <div id="activation-layer" style="display: none;">
        <div class="activation-card">
            <h2>BEM 2026</h2>
            <p style="font-size: 0.8rem; opacity: 0.8;">Enter your activation code to unlock the Elite Training Hub.</p>
            <input type="text" id="user-input-code" placeholder="BEM26-XXXX">
            <button class="option-btn activate-btn" onclick="verifyCode()">ACTIVATE NOW</button>
            <p id="error-message" style="color: #ff4444; font-size: 0.7rem; margin-top: 10px;"></p>
            <p style="font-size: 0.6rem; margin-top: 20px; opacity: 0.5;">This app supports the Ambulance Charity Campaign.</p>
        </div>
    </div>

    <div id="app-wrapper" style="display: none;">
        <div class="ticker">
            <div class="ticker-text">🎯 BEM 2026 OFFICIAL TRAINING HUB • DR. MOHAMED CHOUIDIRA • SMART REVISION 🎯</div>
        </div>

        <div class="app-container">
            <nav class="side-bar">
                <div class="nav-item active" onclick="showHome()"><svg viewBox="0 0 24 24"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg></div>
                <div class="nav-item" onclick="startQuiz('Unit1')"><svg viewBox="0 0 24 24"><path d="M12 2L4.5 20.29l.71.71L12 18l6.79 3 .71-.71z"/></svg></div>
                <div class="nav-item" onclick="startQuiz('Unit2')"><svg viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4z"/></svg></div>
                <div class="nav-item" onclick="startQuiz('Unit3')"><svg viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6z"/></svg></div>
                
                <div class="nav-item" onclick="resetActivation()" style="margin-top: auto; margin-bottom: 20px;">
                    <svg viewBox="0 0 24 24" style="fill: #e74c3c;"><path d="M13 3h-2v10h2V3zm4.83 2.17l-1.42 1.42C17.99 7.86 19 9.81 19 12c0 3.87-3.13 7-7 7s-7-3.13-7-7c0-2.19 1.01-4.14 2.58-5.42L6.17 5.17C4.23 6.82 3 9.26 3 12c0 4.97 4.03 9 9 9s9-4.03 9-9c0-2.74-1.23-5.18-3.17-6.83z"/></svg>
                </div>
            </nav>

            <main class="main-content" id="home-view">
                <h1>Elite Revision</h1>
                <p style="opacity: 0.7; font-size: 0.85rem; margin-bottom: 20px;">Master English for BEM 2026 with Dr. Chouidira.</p>
                
                <div class="card" onclick="startQuiz('Unit1')">
                    <svg class="card-icon" viewBox="0 0 24 24"><path d="M12 2L4.5 20.29l.71.71L12 18l6.79 3 .71-.71z"/></svg>
                    <div class="card-info"><h3>Universal Landmarks</h3><span>Itinerary & Traveling Vocabulary</span></div>
                </div>
                <div class="card" onclick="startQuiz('Unit2')">
                    <svg class="card-icon" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4z"/></svg>
                    <div class="card-info"><h3>Grammar Mastery</h3><span>Passive Voice & Equality</span></div>
                </div>
                <div class="card" onclick="startQuiz('Unit3')">
                    <svg class="card-icon" viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6z"/></svg>
                    <div class="card-info"><h3>Writing & Memories</h3><span>Charity, Figures & Dream Job</span></div>
                </div>
            </main>
        </div>

        <div class="quiz-overlay" id="quiz-overlay">
            <div class="score-bar">
                <span style="color: var(--correct); font-weight: 800;">✓ <span id="c-count">0</span></span>
                <span id="t-count" style="color: var(--gold-solid); font-weight: 800;">TASK 1/10</span>
                <span style="color: var(--wrong); font-weight: 800;">✗ <span id="w-count">0</span></span>
            </div>
            <div id="quiz-box"></div>
            <button onclick="showHome()" style="margin-top: 25px; background: none; border: 1px solid #ff4444; color: #ff4444; padding: 12px; border-radius: 10px; width: 100%; font-weight: bold; font-size: 0.8rem;">END SESSION</button>
        </div>

        <footer class="footer-bar"><div class="signature">DR. MOHAMED CHOUIDIRA</div></footer>
    </div>

    <script src="script.js"></script>
</body>
</html>
